---
---

<section id="hero" aria-label="Introduction" class="min-h-screen flex items-center justify-center relative overflow-hidden">

  <div class="absolute inset-0 bg-gray-950">
    <div class="absolute top-20 left-10 w-96 h-96 bg-[#c20e3d]/40 rounded-full blur-2xl animate-blob"></div>
    <div class="absolute bottom-20 right-10 w-[500px] h-[500px] bg-[#fe6e86]/30 rounded-full blur-2xl animate-blob animation-delay-2000"></div>
    <div class="absolute top-1/3 left-1/2 w-80 h-80 bg-[#ffcdd4]/20 rounded-full blur-2xl animate-blob animation-delay-4000"></div>
  </div>

  <div class="relative z-10 text-center px-6" id="hero-content">
    <p class="text-[#fe6e86] font-medium tracking-widest uppercase text-sm mb-4 opacity-0" data-animate>
      UX Engineer
    </p>
    <h1 class="text-6xl md:text-8xl font-black mb-6 bg-gradient-to-r from-[#ffcdd4] via-[#fe6e86] to-[#c20e3d] bg-clip-text text-transparent opacity-0" data-animate data-delay="100">
      Mercedes de Pascual
    </h1>
    <p class="text-white/60 text-lg md:text-xl max-w-xl mx-auto mb-10 opacity-0" data-animate data-delay="200">
      Designing and building digital products focused on functionality, aesthetics, and user experience.
    </p>
    <div class="flex gap-4 justify-center opacity-0" data-animate data-delay="300">
      <a href="#projects" class="px-8 py-3 bg-gradient-to-r from-[#fe6e86] to-[#c20e3d] rounded-full font-semibold hover:opacity-90 transition-opacity">
        View projects
      </a>
      <a href="#about" class="px-8 py-3 border border-white/20 rounded-full font-semibold hover:bg-white/10 transition-colors">
        About me
      </a>
    </div>
  </div>

</section>

<script>
  import { animate, inView } from 'motion';

  const elements = document.querySelectorAll('[data-animate]');

  elements.forEach((el) => {
    const delay = Number(el.getAttribute('data-delay') || 0) / 1000;
    inView(el, () => {
      animate(el, 
        { opacity: [0, 1], y: [30, 0] },
        { duration: 0.7, delay, easing: 'ease-out' }
      );
    });
  });
</script>