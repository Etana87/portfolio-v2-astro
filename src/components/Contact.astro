---
---

<section id="contact" aria-label="Contact form" class="py-32 px-6">
  <div class="max-w-2xl mx-auto">

    <div class="text-center mb-16">
      <p class="text-[#fe6e86] font-medium tracking-widest uppercase text-sm mb-4">Contact</p>
      <h2 class="text-4xl font-black text-white opacity-0" data-animate>
        Let's <span class="bg-gradient-to-r from-[#fe6e86] to-[#ffcdd4] bg-clip-text text-transparent">work together</span>
      </h2>
      <p class="text-white/50 mt-4 opacity-0" data-animate data-delay="100">
        Have a project in mind? I'd love to hear about it.
      </p>
    </div>

    <form
      id="contact-form"
      action="https://formspree.io/f/xzdjgbkq"
      method="POST"
      class="flex flex-col gap-6 opacity-0"
      data-animate
      data-delay="200"
    >

      <div class="grid md:grid-cols-2 gap-6">
        <div class="flex flex-col gap-2">
          <label for="name" class="text-white/60 text-sm font-medium">Name</label>
          <input
            type="text"
            id="name"
            name="name"
            required
            placeholder="Your name"
            aria-required="true"
            class="bg-white/5 border border-white/10 rounded-xl px-4 py-3 text-white placeholder:text-white/30 focus:outline-none focus:border-[#fe6e86]/50 transition-colors"
          />
        </div>
        <div class="flex flex-col gap-2">
          <label for="email" class="text-white/60 text-sm font-medium">Email</label>
          <input
            type="email"
            id="email"
            name="email"
            required
            placeholder="your@email.com"
            aria-required="true"
            class="bg-white/5 border border-white/10 rounded-xl px-4 py-3 text-white placeholder:text-white/30 focus:outline-none focus:border-[#fe6e86]/50 transition-colors"
          />
        </div>
      </div>

      <div class="flex flex-col gap-2">
        <label for="subject" class="text-white/60 text-sm font-medium">Subject</label>
        <input
          type="text"
          id="subject"
          name="subject"
          required
          placeholder="What's this about?"
          aria-required="true"
          class="bg-white/5 border border-white/10 rounded-xl px-4 py-3 text-white placeholder:text-white/30 focus:outline-none focus:border-[#fe6e86]/50 transition-colors"
        />
      </div>

      <div class="flex flex-col gap-2">
        <label for="message" class="text-white/60 text-sm font-medium">Message</label>
        <textarea
          id="message"
          name="message"
          required
          rows="6"
          placeholder="Tell me about your project..."
          aria-required="true"
          class="bg-white/5 border border-white/10 rounded-xl px-4 py-3 text-white placeholder:text-white/30 focus:outline-none focus:border-[#fe6e86]/50 transition-colors resize-none"
        ></textarea>
      </div>

      <button
        type="submit"
        class="w-full py-4 bg-gradient-to-r from-[#fe6e86] to-[#c20e3d] rounded-xl font-semibold text-white hover:opacity-90 transition-opacity"
      >
        Send message
      </button>

      <!-- Success / Error messages -->
      <p id="success-msg" class="hidden text-center text-green-400 text-sm">
        ✅ Message sent! I'll get back to you soon.
      </p>
      <p id="error-msg" class="hidden text-center text-red-400 text-sm">
        ❌ Something went wrong. Please try again.
      </p>

    </form>

  </div>
</section>

<script>
  import { animate, inView } from 'motion';

  document.querySelectorAll('[data-animate]').forEach((el) => {
    const delay = Number(el.getAttribute('data-delay') || 0) / 1000;
    inView(el, () => {
      animate(el,
        { opacity: [0, 1], y: [30, 0] },
        { duration: 0.7, delay, easing: 'ease-out' }
      );
    });
  });

  const form = document.getElementById('contact-form') as HTMLFormElement;
  const successMsg = document.getElementById('success-msg');
  const errorMsg = document.getElementById('error-msg');

  form.addEventListener('submit', async (e) => {
    e.preventDefault();
    const data = new FormData(form);

    try {
      const response = await fetch(form.action, {
        method: 'POST',
        body: data,
        headers: { Accept: 'application/json' }
      });

      if (response.ok) {
        form.reset();
        successMsg?.classList.remove('hidden');
        errorMsg?.classList.add('hidden');
      } else {
        errorMsg?.classList.remove('hidden');
        successMsg?.classList.add('hidden');
      }
    } catch {
      errorMsg?.classList.remove('hidden');
      successMsg?.classList.add('hidden');
    }
  });
</script>