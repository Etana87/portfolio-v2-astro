---
---

<div
  id="cookie-banner"
  role="dialog"
  aria-label="Cookie consent"
  aria-live="polite"
  class="fixed bottom-0 left-0 right-0 z-50 p-6 bg-gray-900/95 backdrop-blur-md border-t border-white/10 hidden"
>
  <div class="max-w-5xl mx-auto flex flex-col md:flex-row items-center justify-between gap-6">
    
    <div class="flex items-start gap-4">
      <span class="text-2xl">🍪</span>
      <div>
        <p class="text-white font-semibold mb-1">We use cookies</p>
        <p class="text-white/50 text-sm leading-relaxed max-w-xl">
          This website uses Google Analytics cookies to analyze traffic and improve your experience. No personal data is sold or shared with third parties.
          <a href="#" class="text-[#fe6e86] hover:underline ml-1">Learn more</a>
        </p>
      </div>
    </div>

    <div class="flex gap-3 shrink-0">
      <button
        id="cookie-decline"
        class="px-6 py-2.5 border border-white/20 rounded-full text-white/70 text-sm font-medium hover:bg-white/10 transition-colors"
      >
        Decline
      </button>
      <button
        id="cookie-accept"
        class="px-6 py-2.5 bg-gradient-to-r from-[#fe6e86] to-[#c20e3d] rounded-full text-white text-sm font-semibold hover:opacity-90 transition-opacity"
      >
        Accept
      </button>
    </div>

  </div>
</div>

<script>
  const banner = document.getElementById('cookie-banner');
  const acceptBtn = document.getElementById('cookie-accept');
  const declineBtn = document.getElementById('cookie-decline');

  // Show banner if no decision saved
  const consent = localStorage.getItem('cookie-consent');
  if (!consent) {
    banner?.classList.remove('hidden');
  }

  // If previously accepted, load GA
  if (consent === 'accepted') {
    loadGA();
  }

  acceptBtn?.addEventListener('click', () => {
    localStorage.setItem('cookie-consent', 'accepted');
    banner?.classList.add('hidden');
    loadGA();
  });

  declineBtn?.addEventListener('click', () => {
    localStorage.setItem('cookie-consent', 'declined');
    banner?.classList.add('hidden');
  });

  function loadGA() {
    const script = document.createElement('script');
    script.src = 'https://www.googletagmanager.com/gtag/js?id=G-00KD3854NZ';
    script.async = true;
    document.head.appendChild(script);

    script.onload = () => {
      (window as any).dataLayer = (window as any).dataLayer || [];
      function gtag(...args: any[]){ (window as any).dataLayer.push(args); }
      gtag('js', new Date());
      gtag('config', 'G-00KD3854NZ');
    };
  }
</script>